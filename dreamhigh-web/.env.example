# Gọi trực tiếp API (production / khi không dùng proxy Vite)
# Để trống khi dev: FE dùng proxy /api → http://127.0.0.1:3000
# VITE_API_URL=http://localhost:3000/api
#
# Render (FE): có thể dùng VITE_API_URL hoặc PUBLIC_API_URL — inject lúc npm start
# PUBLIC_API_URL=https://your-api.onrender.com/api

# Google Sign-In — Web client ID (Giống GOOGLE_CLIENT_ID trên API)
# Authorized JavaScript origins: http://localhost:5175
# VITE_GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
