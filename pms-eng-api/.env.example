# ============================================================
# DreamHigh PMS — Environment Variables (Aiven PostgreSQL)
# Copy: cp .env.example .env  và điền thông tin từ Aiven Console
# Aiven Console > Project > Service > Overview > Connection information
# ============================================================

# ─── DATABASE (Aiven PostgreSQL) ─────────────────────────────
# Lấy từ: Aiven Console > Connection information > "Connection URI"
# ⚠️  Bắt buộc có ?sslmode=require cho Aiven
# ⚠️  Port của Aiven KHÔNG phải 5432, thường là 5 chữ số (ví dụ: 12345)

# URL dùng cho Prisma Client runtime (có thể dùng pgbouncer pooler nếu có)
DATABASE_URL="postgresql://avnadmin:AVNS_REPLACE_ME@pg-REPLACE-ME.aivencloud.com:PORT/dreamhigh_pms?sslmode=require"

# URL trực tiếp dùng cho migrate/generate (bắt buộc với Aiven để bypass pooler)
# Thường giống DATABASE_URL, trỏ thẳng vào PostgreSQL port
DIRECT_URL="postgresql://avnadmin:AVNS_REPLACE_ME@pg-REPLACE-ME.aivencloud.com:PORT/dreamhigh_pms?sslmode=require"

# ─── App ─────────────────────────────────────────────────────
NODE_ENV="development"
PORT=3000

# Production: origin frontend được phép gọi API (credentials). Cách nhau b��i dấu ph��y, không có khoảng th��a sau khi trim.
# Ví dụ: CORS_ORIGINS="https://app.dreamhigh.vn,https://www.dreamhigh.vn"
# CORS_ORIGINS=

# ─── JWT (thêm khi tích hợp Auth module) ─────────────────────
# JWT_SECRET="change-me-to-a-long-random-string"
# JWT_EXPIRES_IN="7d"

# ─── Google Sign-In (Web client ID từ Google Cloud Console) ──
# Dùng chung Client ID với FE (VITE_GOOGLE_CLIENT_ID). Không cần client secret cho luồng id_token.
# GOOGLE_CLIENT_ID="xxxx.apps.googleusercontent.com"
